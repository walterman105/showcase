#!/bin/sh
set -e

BTSTACK_PLIST="/var/jb/Library/LaunchDaemons/ch.ringwald.BTstack.plist"
BLUETOOTHD_PLIST="/System/Library/LaunchDaemons/com.apple.bluetoothd.plist"

launchctl_path() {
    for tool in /var/jb/usr/bin/launchctl /var/jb/bin/launchctl /bin/launchctl /usr/bin/launchctl; do
        if [ -x "$tool" ]; then
            echo "$tool"
            return 0
        fi
    done
    return 1
}

case "$1" in
    remove|deconfigure|upgrade)
        killall carplay_services 2>/dev/null || true
        killall carplay_bt 2>/dev/null || true
        killall Showcase 2>/dev/null || true
        if [ -f "$BTSTACK_PLIST" ]; then
            if LAUNCHCTL="$(launchctl_path)"; then
                "$LAUNCHCTL" unload "$BTSTACK_PLIST" 2>/dev/null || true
            fi
        fi
        killall BTdaemon 2>/dev/null || true

        if [ -f "$BLUETOOTHD_PLIST" ]; then
            if LAUNCHCTL="$(launchctl_path)"; then
                "$LAUNCHCTL" load "$BLUETOOTHD_PLIST" 2>/dev/null || true
            fi
        fi
        ;;
esac

exit 0
